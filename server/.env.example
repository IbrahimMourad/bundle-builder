PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# Supabase is OPTIONAL. Leave these blank to run fully offline from the
# bundled local seed JSON (server/src/data/catalog.json).
# When both are set, the catalog is served from Supabase using the anon key,
# which is restricted to read-only access by a row-level security policy.
SUPABASE_URL=
SUPABASE_ANON_KEY=
